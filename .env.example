# MCP Proxy Gateway Environment Configuration
# Copy this file to .env and customise as needed

# ── Server binding ────────────────────────────────────────────────────────────
PROXY_HOST=0.0.0.0
PROXY_WS_PORT=8765
PROXY_HTTP_PORT=8088

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Set to true to emit JSON Lines (good for log aggregators like Loki / CloudWatch)
JSON_LOGS=false

# ── MCP1 local server ─────────────────────────────────────────────────────────
MCP1_ENABLED=true
MCP1_HOST=127.0.0.1
MCP1_PORT=9001

# ── Thunai MCP endpoint ───────────────────────────────────────────────────────
THUNAI_ENABLED=true
THUNAI_MCP_URL=https://api.thunai.ai/mcp-service/thunai/service/mcp-sse/mcp

# ── Resilience ────────────────────────────────────────────────────────────────
CB_FAILURE_THRESHOLD=5
CB_RECOVERY_TIMEOUT_S=30.0
REQUEST_TIMEOUT_S=30.0
HEARTBEAT_INTERVAL_S=15.0
RECONNECT_INTERVAL_S=5.0
